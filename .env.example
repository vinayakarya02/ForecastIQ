# Copy to .env and adjust. Consumed by src/forecastiq/config.py.

# ---- Database ----
# SQLite (default, zero-config):
FORECASTIQ_DB_URL=sqlite:///forecastiq.db
# PostgreSQL example:
# FORECASTIQ_DB_URL=postgresql+psycopg2://user:password@localhost:5432/forecastiq

# ---- Paths (override config.yaml if set) ----
FORECASTIQ_RAW_CSV=data/raw/global_superstore.csv

# ---- Logging ----
FORECASTIQ_LOG_LEVEL=INFO
