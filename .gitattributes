# Normalize line endings to LF in the repository; check out native on each OS.
* text=auto

# Shell scripts must stay LF even on Windows checkouts (Docker entrypoint).
*.sh text eol=lf

# Treat binary assets as binary (no line-ending or diff munging).
*.png  binary
*.jpg  binary
*.jpeg binary
*.xls  binary
*.xlsx binary
*.db   binary
*.sqlite binary
